# Template for the host-run govee2mqtt during local testing.
#
# Copy this to a file named .env in the repo root, fill in your Govee
# credentials, and run `cargo run -- serve`. dotenvy loads .env automatically;
# the root .env is gitignored so your credentials stay out of git.
#
#   cp dev/.env.example .env
#   $EDITOR .env
#   cargo run -- serve

# Govee account credentials. Email + password drive the undocumented API
# (device list, scenes, control of shared devices); the API key drives the
# documented platform API. Provide what you have.
GOVEE2MQTT_EMAIL=you@example.com
GOVEE2MQTT_PASSWORD=changeme
GOVEE2MQTT_API_KEY=changeme

# Point at the dev stack's mosquitto, published to the host on 1883 by
# dev/docker-compose.dev.yml. govee2mqtt runs on the host (not in the stack) so
# it has LAN access for device discovery.
GOVEE2MQTT_MQTT_HOST=localhost
GOVEE2MQTT_MQTT_PORT=1883

# The dev broker allows anonymous access, so MQTT user/password are unset here.
# Uncomment and set both if you secure the broker.
#GOVEE2MQTT_MQTT_USER=
#GOVEE2MQTT_MQTT_PASSWORD=

# C or F for the temperature entities.
GOVEE2MQTT_TEMPERATURE_SCALE=C

# Logging. info is plenty for normal use; bump specific modules to trace when
# debugging, eg: RUST_LOG=info,govee2mqtt::hass_mqtt=trace
RUST_LOG=info
